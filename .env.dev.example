# ==========================================================
# TGO Development Environment Configuration
# ==========================================================
# Copy this file to .env.dev and start the full stack with:
#   cp .env.dev.example .env.dev
#   make dev
#
# Container-to-container traffic uses Docker Compose service names.
# Browser-facing frontend configuration still targets localhost ports.
# ==========================================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================================
# Database / Redis (inside Docker Compose)
# ==========================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_DB=tgo
POSTGRES_USER=tgo
POSTGRES_PASSWORD=tgo
DATABASE_URL=postgresql+asyncpg://tgo:tgo@postgres:5432/tgo

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================================
# Host-exposed development ports
# ==========================================================
TGO_API_PORT=8000
TGO_AI_PORT=8081
TGO_RAG_PORT=18082
TGO_PLATFORM_PORT=8003
TGO_WORKFLOW_PORT=8004
TGO_PLUGIN_RUNTIME_PORT=8090
TGO_DEVICE_CONTROL_PORT=8085
TGO_WEB_PORT=5173
TGO_WIDGET_PORT=5174

# ==========================================================
# Internal service URLs (container-to-container)
# ==========================================================
API_SERVICE_URL=http://tgo-api:8000
API_INTERNAL_SERVICE_URL=http://tgo-api:8001
AI_SERVICE_URL=http://tgo-ai:8081
INTENT_AUTOMATION_ENABLED=true
BUSINESS_QUERY_MODE=demo
# 自建订单/物流接口：将 BUSINESS_QUERY_MODE 改为 http 后启用。
# 支持 GET 或 POST；认证支持 none、bearer、api_key、basic。
BUSINESS_QUERY_TIMEOUT=5
BUSINESS_API_BASE_URL=https://business-api.example.com
BUSINESS_API_ORDER_PATH=/v1/orders/query
BUSINESS_API_LOGISTICS_PATH=/v1/logistics/query
BUSINESS_API_METHOD=POST
BUSINESS_API_AUTH_MODE=none
BUSINESS_API_AUTH_TOKEN=
BUSINESS_API_KEY_HEADER=X-API-Key
BUSINESS_API_BASIC_USERNAME=
BUSINESS_API_BASIC_PASSWORD=
# 返回示例：{"code":"0","data":{...}}。若没有业务状态码，SUCCESS_FIELD 留空。
BUSINESS_API_DATA_PATH=data
BUSINESS_API_SUCCESS_FIELD=code
BUSINESS_API_SUCCESS_VALUE=0
# 以下字段支持点号路径，例如 delivery.status。
BUSINESS_API_TENANT_ID_FIELD=tenant_id
BUSINESS_API_CUSTOMER_ID_FIELD=customer_id
BUSINESS_API_ORDER_NO_FIELD=order_no
BUSINESS_API_ORDER_STATUS_FIELD=status
BUSINESS_API_ORDER_AMOUNT_FIELD=amount_minor
BUSINESS_API_ORDER_AMOUNT_UNIT=minor
BUSINESS_API_ORDER_CURRENCY_FIELD=currency
BUSINESS_API_ORDER_CREATED_AT_FIELD=created_at
BUSINESS_API_LOGISTICS_STATUS_FIELD=status
BUSINESS_API_LOGISTICS_CARRIER_FIELD=carrier
BUSINESS_API_LOGISTICS_TRACKING_NO_FIELD=tracking_no
BUSINESS_API_LOGISTICS_UPDATED_AT_FIELD=updated_at
RAG_SERVICE_URL=http://tgo-rag:8082
PLATFORM_SERVICE_URL=http://tgo-platform:8003
WORKFLOW_SERVICE_URL=http://tgo-workflow:8000
PLUGIN_RUNTIME_URL=http://tgo-plugin-runtime:8090
DEVICE_CONTROL_SERVICE_URL=http://tgo-device-control:8085
WUKONGIM_SERVICE_URL=http://wukongim:5001
WUKONGIM_ENABLED=true
WK_EXTERNAL_IP=127.0.0.1
WK_EXTERNAL_WSADDR=localhost:5200

# ==========================================================
# Frontend browser-side environment variables
# ==========================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WIDGET_PREVIEW_URL=http://localhost:5174
VITE_WIDGET_SCRIPT_BASE=http://localhost:5174/tgo-widget-sdk.js
VITE_WIDGET_DEMO_URL=http://localhost:5174/demo.html
VITE_DEBUG_MODE=true

# ==========================================================
# Security
# ==========================================================
SECRET_KEY=dev_secret_key_change_in_production_12345678901234567890
INTERNAL_API_KEY=dev_internal_service_key_change_in_production_1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================================
# Storage / external services
# ==========================================================
STORAGE_TYPE=local
STORE_SERVICE_URL=https://store.tgo.ai
STORE_WEB_URL=https://store.tgo.ai

# WeCom inbound media ingestion is opt-in. Generate a development key with:
# openssl rand -base64 32
MEDIA_INGESTION_ENABLED=false
MEDIA_CLEANUP_ENABLED=true
MEDIA_STORAGE_PATH=/data/media
MEDIA_ENCRYPTION_KEY=
MEDIA_ENCRYPTION_KEY_ID=local-media-v1
MEDIA_RETENTION_DAYS=30
MEDIA_IMAGE_MAX_BYTES=2097152
MEDIA_VOICE_MAX_BYTES=2097152
MEDIA_IMAGE_MAX_PIXELS=25000000
MEDIA_IMAGE_MAX_FRAMES=20
MEDIA_VOICE_MAX_DURATION_SECONDS=300
